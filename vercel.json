{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build:web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "regions": [
    "iad1"
  ],
  "env": {
    "VERVEMIND_ENV": "production"
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "IN"
        },
        {
          "type": "host",
          "value": "(www\\.)?vervemindai\\.com"
        }
      ],
      "destination": "/india",
      "permanent": false
    },
    {
      "source": "/in",
      "destination": "/india",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "medspa.vervemindai.com" }],
      "destination": "https://medspa.vervemindai.com/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "dental.vervemindai.com" }],
      "destination": "https://dental.vervemindai.com/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "hvac.vervemindai.com" }],
      "destination": "https://hvac.vervemindai.com/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "roofing.vervemindai.com" }],
      "destination": "https://roofing.vervemindai.com/$1"
    },
    {
      "source": "/blitz(.*)",
      "destination": "/blitz/index.html"
    },
    {
      "source": "/seo(.*)",
      "destination": "/seo/index.html"
    },
    {
      "source": "/voice(.*)",
      "destination": "/voice/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}