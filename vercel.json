{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "框架": null,
  "routes": [
    {
      "src": "^/in(.*)$",
      "dest": "https://vervemind-web.vercel.app/in$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "https://vervemind-web.vercel.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "https://vervemind-web.vercel.app/$1"
    }
  ],
  "regions": ["iad1"],
  "env": {
    "VERVEMIND_ENV": "production"
  }
}
