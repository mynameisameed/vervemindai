{
  "name": "vervemindai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:blitz": "npm run dev --workspace=apps/blitz",
    "dev:seo": "npm run dev --workspace=apps/seo",
    "dev:voice": "npm run dev --workspace=apps/voice",
    "build:web": "npm run build --workspace=apps/web",
    "build:blitz": "npm run build --workspace=apps/blitz",
    "build:seo": "npm run build --workspace=apps/seo",
    "build:voice": "npm run build --workspace=apps/voice",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1"
  }
}
